CONFIG_PLAT_ARCH_32BIT=y
CONFIG_DEBUG_LOG=y
CONFIG_IOT=y
CONFIG_IOT_NBIOT=y
CONFIG_IOT_NBIOT_OBJECTS_MAX_CNT=16
CONFIG_IOT_NBIOT_RESOURCES_MAX_CNT_PER_OBJECT=16
CONFIG_SEND_BUF_LEN_MAX=256
CONFIG_RECV_BUF_LEN_MAX=256
CONFIG_IOT_NBIOT_M5311=y
CONFIG_BUILD_EXAMPLE=y
CONFIG_C_FLAGS="-g"
CONFIG_LINK_LIBS="-lpthread"